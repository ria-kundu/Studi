API_BASE_URL=http://localhost:3000/api
FRONTEND_ORIGIN=http://localhost:5173

# Required for protected-route success tests.
# Get this from a signed-in Firebase client user by calling currentUser.getIdToken().
FIREBASE_ID_TOKEN=paste-valid-firebase-id-token-here

# Alternative to FIREBASE_ID_TOKEN:
# If these three values are set, the test runner signs in with Firebase Auth REST API.
# If the test user does not exist yet, it creates the user and uses the new ID token.
FIREBASE_WEB_API_KEY=paste-firebase-web-api-key-here
FIREBASE_TEST_EMAIL=paste-test-user-email-here
FIREBASE_TEST_PASSWORD=paste-test-user-password-here

# Optional. Use a different Firebase test user that does not yet have a Firestore users/{uid} profile.
# If omitted, fresh-user onboarding tests are skipped.
FIREBASE_ID_TOKEN_NO_PROFILE=paste-valid-token-for-new-test-user-here
